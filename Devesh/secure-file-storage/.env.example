# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secure_file_storage
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_DIALECT=postgres

# Master Encryption Key (CRITICAL - NEVER COMMIT THIS)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=your_64_character_hex_master_key_here

# JWT Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security Configuration
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=3
ACCOUNT_LOCK_DURATION=900000
PASSWORD_MIN_LENGTH=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# File Upload Configuration
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,jpeg,png,zip
UPLOAD_DIR=./uploads

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Cookie Configuration
COOKIE_SECRET=your_cookie_secret_min_32_chars
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./src/logs

# Optional: Future MFA/OTP Configuration
# TOTP_SECRET=your_totp_secret
# SMS_API_KEY=your_sms_api_key
# EMAIL_SERVICE=smtp.gmail.com
# EMAIL_USER=your_email
# EMAIL_PASSWORD=your_email_password
