# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database Configuration
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# Master Encryption Key (CRITICAL - NEVER COMMIT THIS)
MASTER_ENCRYPTION_KEY=59cfafa9ce24d33aac23b4fe2926987d68d38a488575d40a8ba18726aad986c5

# JWT Configuration
JWT_ACCESS_SECRET=5fdbdc19730d7d77c42c86bfc514287a800cc6cacefe64c3f13e83388859c939
JWT_REFRESH_SECRET=2982ce54f437614b72dcd430631e918619e379bf00bae82fd5435d9c059abeed
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security Configuration
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=3
ACCOUNT_LOCK_DURATION=900000
PASSWORD_MIN_LENGTH=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# File Upload Configuration
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,jpeg,png,zip
UPLOAD_DIR=./uploads

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Cookie Configuration
COOKIE_SECRET=0d08a0145b4ac82223289351daaec40bc345a11c3508c7b7e7ac64ddc16e2587
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./src/logs
